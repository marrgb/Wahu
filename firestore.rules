rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow public fetch for a specific team and invite so invitees can see details.
    // We restrict "list" and "write" to authenticated users only.
    match /teams/{teamId} {
      allow get: if true;
      allow list, write: if request.auth != null;

      match /invites/{inviteId} {
        allow get: if true;
        
        // Allow unauthenticated users to ONLY change the status to 'declined'
        // Allow authenticated users full write access
        allow update: if request.auth != null || 
                         (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
                          request.resource.data.status == 'declined');
                          
        allow create, delete, list: if request.auth != null;
      }
    }

    // Default rule for everything else (e.g. users, games, etc.)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}